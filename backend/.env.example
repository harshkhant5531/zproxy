PORT=3001
DATABASE_URL=postgresql://username:password@localhost:5432/aura_integrity
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# Frontend URL for reset links and CORS
FRONTEND_URL=http://localhost:8080
# Comma-separated list; supports exact origins and wildcard subdomains like https://*.vercel.app
CORS_ORIGIN=http://localhost:8080,https://your-production-domain.com,https://*.vercel.app
# Set to false to disable automatic Vercel preview allowance (*.vercel.app)
CORS_ALLOW_VERCEL_PREVIEW_ORIGINS=true
# Set to false to disable automatic private-network origin allowance (10.x, 172.16-31.x, 192.168.x)
CORS_ALLOW_PRIVATE_NETWORK=true

# Google Sign-In
GOOGLE_CLIENT_ID=696854113810-4jucrln1qhv5ik2m4gou2r9vk3u85b4l.apps.googleusercontent.com
GOOGLE_ALLOWED_DOMAIN=darshan.ac.in
